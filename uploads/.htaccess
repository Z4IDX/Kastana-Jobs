# uploads/ — user-supplied files. Serve as static only; never execute code.
php_flag engine off
Options -Indexes -ExecCGI
RemoveHandler .php .phtml .php3 .php4 .php5 .php7 .phar .cgi .pl .py
<FilesMatch "\.(php|phtml|php3|php4|php5|php7|phar|pl|py|cgi|asp|aspx|sh|htaccess)$">
    Require all denied
</FilesMatch>
# Force text type for anything that slips through
AddType text/plain .php .phtml .phar .cgi .pl .py
